#include "BluetoothSerial.h"

int analogPin = 4; // potentiometer wiper (middle terminal) connected to analog pin 3
                    // outside leads to ground and VCC
int val = 0;  // variable to store the value read

void setup() {
  Serial.begin(9600);           //  setup serial
}

void loop() {
  val = analogRead(analogPin);
  Serial.print(-100); // To freeze the lower limit
  Serial.print(" ");
  Serial.print(4200); // To freeze the upper limit
  Serial.print(" ");
  Serial.println(val);
  delay(20);
  // delay(200); // To send all three 'data' points to the plotter  // read the input pin
    // Serial.println(val);          // debug value
}
